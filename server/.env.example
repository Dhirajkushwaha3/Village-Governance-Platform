PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/village_governance
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=development
CORS_ORIGIN=https://village-governance-platform-two.vercel.app/
FRONTEND_URL=
TRUST_PROXY=false
OTP_EXPIRY_MINUTES=5
ESCALATION_HOURS=48
ADMIN_EMAIL=admin@village.local
ADMIN_PASSWORD=change_this_admin_password

# Email Configuration (for OTP delivery)
# Using Gmail: EMAIL_SERVICE=gmail, EMAIL_USER=your@gmail.com, EMAIL_PASSWORD=your_app_password
# Using other providers: Refer to nodemailer documentation for supported services
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# Note: For Gmail, you need to generate an App Password:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create app password for "Mail" and "Windows"
# 4. Use the generated password in EMAIL_PASSWORD
